SELECT TOP (
    CASE 
        WHEN DATEPART(DAY,GETDATE()) = 18 and DATEPART(MONTH,GETDATE()) = 7 THEN 9325
        WHEN DATEPART(DAY,GETDATE()) = 19 and DATEPART(MONTH,GETDATE()) = 7 THEN 11325
        WHEN DATEPART(DAY,GETDATE()) = 20 and DATEPART(MONTH,GETDATE()) = 7 THEN 14325
        WHEN DATEPART(DAY,GETDATE()) = 21 and DATEPART(MONTH,GETDATE()) = 7 THEN 17907
     ELSE 0 END)
    G.ContactKey,
    G.Email,
    G.Id,
    G.Name,
    G.MobilePhone,
    G.Phone
 FROM
   Warmup_Gmail G
WHERE NOT EXISTS
    (SELECT '' FROM Warmup_Historico H WHERE H.ContactKey = G.ContactKey)
UNION
