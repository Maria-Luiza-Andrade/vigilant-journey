    Contact_Salesforce c
WHERE
    NOT EXISTS
        (SELECT '' FROM Warmup_Gmail G WHERE G.ContactKey = c._ContactKey)
    AND NOT EXISTS
        (SELECT '' FROM Warmup_Hotmail H WHERE H.ContactKey = c._ContactKey)
    AND NOT EXISTS
        (SELECT '' FROM Warmup_Yahoo Y WHERE Y.ContactKey = c._ContactKey)
